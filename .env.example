EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# EAS access token (expo.dev -> Account settings -> Access tokens).
# Build-tool auth only — no EXPO_PUBLIC_ prefix, so it is never bundled into the app.
# Export it before running eas commands: set -a && source .env && set +a
EXPO_TOKEN=your-eas-access-token
